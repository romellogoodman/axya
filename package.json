{
  "name": "axya",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,green \"npm:server\" \"npm:client\"",
    "server": "NEXTDRAW_CMD='python3 -m nextdraw' node server/index.js",
    "client": "vite --port=8080 --open",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,scss,css}\" \"server/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,scss,css}\" \"server/**/*.js\"",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules package-lock.json"
  },
  "dependencies": {
    "express": "^5.2.1",
    "flatten-svg": "^0.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "vite": "^8.0.10"
  }
}
